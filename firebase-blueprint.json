{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "apiKey": { "type": "string", "description": "API key for programmatic access" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Mailbox": {
      "title": "Mailbox",
      "description": "A test email address managed by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "address": { "type": "string", "format": "email" },
        "label": { "type": "string" },
        "project": { "type": "string" },
        "notes": { "type": "string" },
        "targetUrl": { "type": "string", "format": "uri", "description": "URL of the app to test" },
        "playStoreUrl": { "type": "string", "format": "uri", "description": "URL of the app on Play Store" },
        "packageName": { "type": "string", "description": "Package name of the app" },
        "webhookUrl": { "type": "string", "format": "uri", "description": "URL to trigger on new email" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "appStatus": { "type": "string", "enum": ["idle", "installing", "installed", "active"] },
        "isAutoPilotEnabled": { "type": "boolean", "description": "Whether auto-pilot is enabled for this mailbox" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "address", "status", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A simulated user action on the app",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mailboxId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["install", "login", "action", "uninstall"] },
        "actionName": { "type": "string", "description": "Name of the action performed" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["mailboxId", "userId", "type", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "An email message received by a mailbox",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mailboxId": { "type": "string" },
        "userId": { "type": "string" },
        "from": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "html": { "type": "string" },
        "links": { 
          "type": "array", 
          "items": { "type": "string", "format": "uri" },
          "description": "Extracted links from the email body"
        },
        "receivedAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["mailboxId", "from", "subject", "receivedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/mailboxes/{mailboxId}": {
      "schema": "Mailbox",
      "description": "Managed test email addresses"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Received email messages"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Simulated user activities"
    }
  }
}
