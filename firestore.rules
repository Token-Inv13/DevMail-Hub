rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - apiKey: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: mailboxes
    // Document ID: mailboxId
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - address: string (required, email format)
    //   - label: string (optional)
    //   - project: string (optional)
    //   - notes: string (optional)
    //   - targetUrl: string (optional)
    //   - webhookUrl: string (optional)
    //   - status: string (required, enum: active, inactive)
    //   - createdAt: timestamp (required)
    //   - lastMessageAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidEmail(email) {
      return email is string && email.matches("^[^@]+@[^@]+\\.[^@]+$");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'apiKey', 'createdAt']) &&
             data.uid == request.auth.uid &&
             (data.email == null || isValidEmail(data.email)) &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    function isValidMailbox(data) {
      return hasOnlyAllowedFields(['id', 'userId', 'address', 'label', 'project', 'notes', 'targetUrl', 'webhookUrl', 'status', 'createdAt', 'lastMessageAt']) &&
             data.userId == request.auth.uid &&
             isValidEmail(data.address) &&
             data.status in ['active', 'inactive'] &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /mailboxes/{mailboxId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidMailbox(request.resource.data);
      allow update: if isDocOwner() && isValidMailbox(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
